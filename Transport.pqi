DATABASE C:\Program Files (x86)\USGS\Phreeqc Interactive 3.8.6-17100\database\phreeqc.dat
TITLE Peridotite dissolution — reactive transport model (1D column, 20 cells, 5 years)
# Stequiometry from Gleeson et al. (2004)

########################################
# 1. PHASES
########################################

PHASES

Enstatite
    Mg1.75Fe0.25Si2O6 + 4H+ + 2H2O = 1.75Mg+2 + 0.25Fe+2 + 2H4SiO4
    -log_k     24.8
    -delta_h   -12.25 kcal
# Murphy and Helgeson (1989)

Dolomite
    CaMg(CO3)2 = Ca+2 + Mg+2 + 2 CO3-2
    -log_k -17.09
    -delta_h -9.436 kcal
    -analytic 31.283 -0.0898 -6438 # 25°C: Hemingway and Robie, 1994; 50-175°C: Bénézeth et al., 2018, GCA 224, 262-275
    -Vm 64.5
# PHREEQC database

Olivine # As forsterite
    Mg1.8Fe0.2SiO4 + 4H+ = 1.8Mg+2 + 0.2Fe+2 + H4SiO4
    -log_k     28.306
    -delta_h   -48.578 kcal
# Ball & Nordstrom (1991)

Lizardite
    Mg2.6Fe0.4Si2O5(OH)4 + 6H+ = 2.6Mg+2 + 0.4Fe+2 + 2H4SiO4 + H2O
    -log_k     33.43
    -delta_h   74 kJ/mol # Werner et al. (2014)
# (GECO Project, 2021) chemical reaction and logk

Pyrolusite # Instead of Birnessita
    MnO2:H2O + 4 H+ + 2 e- = Mn+2 + 3 H2O
    -log_k 41.38
    -delta_h -65.11 kcal
# PHREEQC database

Magnesite
    MgCO3 = Mg+2 + CO3-2
    -log_k   -8.03
    -delta_h -7.34 kcal
# log_k:    Pokrovsky & Schott (1999), Table 4; tomado de
#           Christ & Hostetler (1970); Nordstrom et al. (1990)
# delta_h:  Calculado por Ley de Hess:
#           dH°rxn = dH°f(Mg2+) + dH°f(CO3 2-) - dH°f(MgCO3)
#           = (-466.80) + (-677.14) - (-1113.3) = -30.64 kJ/mol = -7.32 kcal/mol
#           dH°f(MgCO3): Robie & Hemingway (1995), USGS Bulletin 2131
#           dH°f(Mg2+):  Csonka et al. (1979), J. Chem. Thermodynamics 11, 141
#           dH°f(CO3 2-): Wagman et al. (1982), NBS Tables, J. Phys. Chem. Ref. Data 11

Siderite
    FeCO3 = Fe+2 + CO3-2
    -log_k -10.89
    -delta_h -2.48 kcal
    -Vm 29.2
# PHREEQC database

Rhodochrosite
    MnCO3 = Mn+2 + CO3-2
    -log_k -11.13
    -delta_h -1.43 kcal
    -Vm 31.1
# PHREEQC database

Aragonite
    CaCO3 = CO3-2 + Ca+2
    -log_k -8.336
    -delta_h -2.589 kcal
    -analytic -171.9773 -0.077993 2903.293 71.595
    -Vm 34.04
# PHREEQC database

Calcite
    CaCO3 = CO3-2 + Ca+2
    -log_k -8.48
    -delta_h -2.297 kcal
    -analytic 17.118 -0.046528 -3496 # 0-250°C, Ellis, 1959, Plummer and Busenberg, 1982
    -Vm 36.9 cm3/mol # MW (100.09 g/mol) / rho (2.71 g/cm3)
# PHREEQC database

########################################
# 2. SOLUTIONS
# Celda 0: agua de entrada (lluvia fresca, se renueva cada shift)
# Celdas 1-20: perfil inicial del suelo (todas iguales)
########################################

SOLUTION 0          # agua de entrada — lluvia fresca renovada cada shift
    temp      27    # IDEAM (2006), costa Caribe colombiana
    pH        5.5   # lluvia tropical costa Caribe (IDEAM, 2006)
    pe        4     # condiciones moderadamente oxidantes
    units     mol/kgw
    Alkalinity 0
SOLUTION 1-20       # perfil inicial del suelo — 20 celdas de 0.05 m = 1 m total
    temp      27
    pH        5.5
    pe        4
    units     mol/kgw
    Alkalinity 0

########################################
# 3. EQUILIBRIUM_PHASES 1-20
# Cambios en el pCO2 en función de la profundidad y el DIC
########################################

EQUILIBRIUM_PHASES 1-2
    CO2(g)          -3.5    # atmosfera abierta ~400 ppm (Friedlingstein et al., 2025)
    Dolomite        -0.5    0.00217  # tampón geoquímico; cantidad inicial DRX (Ascencio Monroy, 2024)
    Pyrolusite       0.0    0.02992  # alta reactividad ? equilibrio inmediato; cantidad inicial DRX
    Magnesite        0.0   0.0       # carbonato secundario Mg
    Rhodochrosite    0.0   0.0       # carbonato secundario Mn
    Chalcedony   0.0   0.0    # control Si
    Fe(OH)3(a)   0.0   0.0    # contro Fe3+

