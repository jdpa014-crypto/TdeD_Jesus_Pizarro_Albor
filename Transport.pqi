########################################
# 4. RATES — Palandri & Kharaka (2004)
########################################

RATES

Olivine
-start
10 moles = 0
20 IF (M <= 1e-20) THEN GOTO 200
30 IF (SI("Olivine") >= 0) THEN GOTO 200

40 rssa   = PARM(1)
50 r_conc = PARM(2)
60 por    = PARM(3)
70 afrac  = PARM(4)
80 vol    = PARM(5)
90 a0 = rssa * r_conc * afrac / por

100 dif_temp = 1/TK - 1/298.15

110 k_acid = 10^(-6.85)
120 e_acid = 67.2
130 n_acid = 0.47
140 k_neut = 10^(-10.64)
150 e_neut = 79
160 hplus  = ACT("H+")

170 r_acid  = k_acid * EXP((-e_acid/8.314e-3)*dif_temp) * (hplus^n_acid)
180 r_neut  = k_neut * EXP((-e_neut/8.314e-3)*dif_temp)
190 r_total = r_acid + r_neut

200 rate = (a0/vol) * (M/M0)^0.67 * r_total * (1-SR("Olivine"))
210 moles = rate * TIME
220 SAVE moles
-end

Enstatite
-start
10 moles = 0
20 IF (M <= 1e-20) THEN GOTO 200
30 IF (SI("Enstatite") >= 0) THEN GOTO 200

40 rssa   = PARM(1)
50 r_conc = PARM(2)
60 por    = PARM(3)
70 afrac  = PARM(4)
80 vol    = PARM(5)
90 a0 = rssa * r_conc * afrac / por

100 dif_temp = 1/TK - 1/298.15

110 k_acid = 10^(-9.02)
120 e_acid = 80
130 n_acid = 0.6
140 k_neut = 10^(-12.72)
150 e_neut = 80
160 hplus  = ACT("H+")

170 r_acid  = k_acid * EXP((-e_acid/8.314e-3)*dif_temp) * (hplus^n_acid)
180 r_neut  = k_neut * EXP((-e_neut/8.314e-3)*dif_temp)
190 r_total = r_acid + r_neut

200 rate = (a0/vol) * (M/M0)^0.67 * r_total * (1-SR("Enstatite"))
210 moles = rate * TIME
220 SAVE moles
-end

Lizardite
-start
10 moles = 0
20 IF (M <= 1e-20) THEN GOTO 230
30 IF (SI("Lizardite") >= 0) THEN GOTO 230
40 IF (M0 <= 0) THEN GOTO 230

50 rssa   = PARM(1)
60 r_conc = PARM(2)
70 por    = PARM(3)
80 afrac  = PARM(4)
90 vol    = PARM(5)
100 a0 = rssa * r_conc * afrac / por

110 dif_temp = 1/TK - 1/298.15

120 k_acid = 10^(-5.70)
130 e_acid = 75.5
140 n_acid = 0.8
150 k_neut = 10^(-12.40)
160 e_neut = 56.6
170 hplus  = ACT("H+")

180 r_acid  = k_acid * EXP((-e_acid/8.314e-3)*dif_temp) * (hplus^n_acid)
190 r_neut  = k_neut * EXP((-e_neut/8.314e-3)*dif_temp)
200 r_total = r_acid + r_neut

210 rate = (a0/vol) * (M/M0)^0.67 * r_total * (1-SR("Lizardite"))
220 IF (rate * TIME > M) THEN rate = M / TIME * 0.9

230 moles = rate * TIME
240 SAVE moles
-end

########################################
# 5. KINETICS 1-20
# Replicado en todas las celdas
# -steps: 15 días divididos en pasos de 1 día por celda por shift
# Fórmulas estructurales: EPMA Gleeson et al. (2004), normalización DHZ (1992)
# Porcentajes modales: DRX Ascencio Monroy (2024)
# PARMS: SSA=0.252 m2/g (White & Brantley 2003, factor rugosidad ?=100)
#        r_conc=25 g/L, por=0.14, vol=1 L (Vienne et al. 2022)
########################################

KINETICS 1-20

Olivine # As forsterite — Fo90 (Gleeson et al. 2004)
    -formula  Mg1.8Fe0.2SiO4 1.0
    -m0  0.02004
    -m   0.02004
    -parms  0.3276 25 0.14 0.1172 1.0
    -tol  1e-9

Enstatite # En91 (Gleeson et al. 2004)
    -formula  Mg1.75Fe0.25Si2O6 1.0
    -m0  0.03216
    -m   0.03216
    -parms  0.3276 25 0.14 0.2738 1.0
    -tol  1e-9

Lizardite # Lizardita + Antigorita sumadas (Ascencio Monroy 2024)
    -formula  Mg2.6Fe0.4Si2O5(OH)4 1.0
    -m0  0.04489
    -m   0.04489
    -parms  0.3276 25 0.14 0.489 1.0
    -tol  1e-9

-steps 1296000 in 15    # 15 días por shift, pasos de 1 día (86400 s)
INCREMENTAL_REACTIONS true

########################################
# 6. TRANSPORT
# 20 celdas de 0.05 m = 1 m de perfil total
# 100 shifts x 15 días = 1500 días (~5 ańos, 5 renovaciones del perfil)
# time_step = 15 días = 1296000 s (velocidad de poro: 0.05m/15d = 3.3 mm/d)
# Transporte puramente advectivo (dispersividad = 0)
########################################

TRANSPORT
    -cells          20
    -shifts         100
    -time_step      1296000     # 15 días en segundos (15 × 86400)
    -lengths        20*0.05     # celdas de 0.05 m — 1 metro total
    -dispersivities 20*0        # advectivo puro (Vienne et al. 2022)
    -punch_cells    1-20

########################################
# 7. SELECTED_OUTPUT y USER_PUNCH
########################################

SELECTED_OUTPUT
    -file        Peridotite_transport.txt
    -reset       false
    -high_precision true

USER_PUNCH
-headings shift cell time_d pH Olivine Enstatite Lizardite Magnesite Chalcedony Fe(OH)3 Rhodochrosite Mg Fe Si C HCO3 MgHCO3 FeHCO3 CO3 CO2aq alkalinity
-start
10 sh     = STEP_NO                        # número de shift (1-100)
20 cel    = CELL_NO                        # número de celda (1-20)
30 t      = STEP_NO * 1296000 / 86400     # tiempo en días (determinista, evita ambigüedad de TOTAL_TIME)
40 pH_val = -LA("H+")

# Moles actuales de cada fase mineral
50 ol_mol  = KIN("Olivine")
60 en_mol  = KIN("Enstatite")
70 liz_mol = KIN("Lizardite")

80 mag_mol = EQUI("Magnesite")
90 cal_mol = EQUI("Chalcedony")
100 fe_mol = EQUI("Fe(OH)3(a)")
110 rho_mol = EQUI("Rhodochrosite")

# Concentraciones en solución (mol/kg x1e5)
120 Mg_val  = TOT("Mg") * 1e5
130 Fe_val  = TOT("Fe") * 1e5
140 Si_val  = TOT("Si") * 1e5
150 C_val   = TOT("C")  * 1e5

# Especiación del carbono (mol/kg x1e5)
160 HCO3_val   = MOL("HCO3-")   * 1e5
170 MgHCO3_val = MOL("MgHCO3+") * 1e5
180 FeHCO3_val = MOL("FeHCO3+") * 1e5
190 CO3_val    = MOL("CO3-2")   * 1e5
200 CO2aq_val  = MOL("CO2")     * 1e5
210 alk_val = ALK * 1e3

220 PUNCH sh, cel, t, pH_val, ol_mol, en_mol, liz_mol, mag_mol, cal_mol, fe_mol, rho_mol, Mg_val, Fe_val, Si_val, C_val, HCO3_val, MgHCO3_val, FeHCO3_val, CO3_val, CO2aq_val, alk_val
-end

########################################
# 8. USER_GRAPH
########################################

USER_GRAPH 1
    -chart_title "Mineral moles over time"
    -axis_titles "Time (days)" "Moles"
    -axis_scale x_axis 0 1500
    -initial_solutions false
-start
10 graph_x STEP_NO * 15          # días
20 graph_y KIN("Olivine")
30 graph_y EQUI("Magnesite")
40 graph_y EQUI("Rhodochrosite")
-end

USER_GRAPH 2
    -chart_title "pH over time"
    -axis_titles "Time (days)" "pH"
    -axis_scale x_axis 0 1500
    -initial_solutions false
-start
10 graph_x STEP_NO * 15
20 graph_y -LA("H+")
-end

END